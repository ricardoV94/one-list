{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "predeploy": ["bash stamp-deploy.sh"],
    "public": ".",
    "ignore": ["firebase.json", ".firebase", "node_modules", "README.md", "*.sh", "firestore.rules", ".git", ".gitignore"],
    "headers": [
      {
        "source": "sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}

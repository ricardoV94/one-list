rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null
        && request.auth.token.email in get(/databases/$(database)/documents/config/allowedUsers).data.emails;
    }

    function isOwner() {
      return resource.data.owner == request.auth.token.email;
    }

    match /config/{doc} {
      allow read: if isAllowed();
      allow write: if false;
    }

    match /entries/{entryId} {
      allow read: if isAllowed()
        && (resource.data.owner == request.auth.token.email || resource.data.shared == true);

      allow create: if isAllowed()
        && request.resource.data.owner == request.auth.token.email
        && request.resource.data.shared is bool;

      // Owner can update anything except transferring ownership
      allow update: if isAllowed()
        && isOwner()
        && request.resource.data.owner == resource.data.owner;

      // Collaborators can edit shared entries but not change owner or shared status
      allow update: if isAllowed()
        && resource.data.shared == true
        && request.resource.data.owner == resource.data.owner
        && request.resource.data.shared == resource.data.shared;

      allow delete: if isAllowed() && isOwner();

      // Version history: one immutable doc per committed editing session.
      // Anyone who can reach the parent note can read and add versions (a collaborator
      // editing a shared note must be able to archive their result — that is the whole
      // recoverability guarantee). Versions are NEVER updated: allowing an update would
      // let a stale device rewrite an archived version, which is the data loss this
      // design exists to prevent. Delete IS allowed — clear/delete-version are
      // user-initiated, and this is not a create-only forever-ledger.
      // NOTE ON ORDERING: rules evaluate each write against the ALREADY-COMMITTED database
      // — a get() here cannot see other writes in the same batch. So the parent note must
      // already exist when a version doc is written (create the note first, in a separate
      // write), and version docs should be deleted BEFORE the note (deleted after, they
      // lose ownsNote() and fall back to the allowlist-wide orphan-cleanup rule below).
      match /history/{versionId} {
        function noteExists() {
          return exists(/databases/$(database)/documents/entries/$(entryId));
        }
        function noteData() {
          return get(/databases/$(database)/documents/entries/$(entryId)).data;
        }
        // Same reach as the parent note: owner, or anyone allowlisted if it's shared.
        function canReachNote() {
          return isAllowed() && noteExists()
            && (noteData().owner == request.auth.token.email || noteData().shared == true);
        }
        function ownsNote() {
          return isAllowed() && noteExists()
            && noteData().owner == request.auth.token.email;
        }
        allow read: if canReachNote();

        // Collaborators MUST be able to archive their own result on a shared note — that
        // is the recoverability guarantee; without it their overwritten text is lost.
        // Deliberately NO schema validation here: a `hasOnly([...])` field lock would
        // start DENYING archive writes the day a field is added to a version doc, and a
        // denied write is a silently lost version — a far worse failure than a stray field.
        allow create: if canReachNote();

        // Deletion is OWNER-ONLY, matching the note's own delete rule and the UI (clear /
        // delete-version are shown only to the owner). Not a trust boundary — it just
        // keeps the rules from permitting a destructive thing the app never offers.
        allow delete: if ownsNote();

        // Orphan cleanup: once the parent note is gone, ownsNote() can never hold again,
        // which used to strand any version the pre-delete sweep missed (offline delete
        // over a partial cache, or the SDK's cache lying about the subcollection) as
        // permanently undeletable garbage. Ownership is unknowable here (the note doc no
        // longer exists), so any allowlisted user may collect the orphans. Same spirit as
        // the rule above: not a trust boundary, versions of a deleted note guard nothing.
        allow delete: if isAllowed() && !noteExists();

        // CONTENT is immutable: an update that rewrote it would let a stale device destroy
        // an archived version, which is precisely the data loss this design prevents.
        //
        // `base` is not content — it is structural metadata (which version this one derived
        // from). It MUST be repairable: deleting a version leaves its children pointing at a
        // doc that no longer exists, and that hole makes every version above it look orphaned.
        // So deletion re-parents the children onto the deleted version's own parent.
        // Owner-only, same as delete, and nothing but `base` may change.
        allow update: if ownsNote()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['base'])
          && request.resource.data.content == resource.data.content;
      }
    }
  }
}
